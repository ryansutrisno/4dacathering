---
import { hero, heroProduct } from '../../data/copy';
import { buildWALink } from '../../utils/wa';

const waLink = buildWALink(hero.ctaMessage);
---

<section class="relative min-h-[80vh] flex items-center overflow-hidden bg-surface-container-low">
  <div class="max-w-[1200px] mx-auto px-gutter grid grid-cols-1 md:grid-cols-12 gap-lg items-center py-xl">
    <div class="md:col-span-7 z-10 order-2 md:order-1">
      <div class="inline-flex items-center gap-xs bg-secondary-fixed text-on-secondary-fixed px-3 py-1 rounded-full mb-base">
        <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
        <span class="text-label-sm font-label-sm uppercase tracking-widest">{hero.badge}</span>
      </div>
      <h1 class="text-display-lg-mobile md:text-display-lg font-display-lg text-smoke-gradient leading-tight mb-base">
        {hero.headline}<br />{hero.headlineAccent}
      </h1>
      <p class="text-body-lg font-body-lg text-on-surface-variant max-w-xl mb-lg">
        {hero.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-base">
        <a
          class="bg-primary text-on-primary px-6 py-3 md:px-xl md:py-md rounded-lg font-label-md text-center soot-shadow active:scale-[0.98] transition-all hover:bg-secondary flex items-center justify-center gap-sm w-full md:w-auto"
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="material-symbols-outlined">chat</span>
          {hero.ctaLabel}
        </a>
        <a class="border-2 border-outline text-on-surface py-md rounded-lg font-label-md text-center hover:bg-surface-variant transition-colors px-6" href="#menu">
          {hero.secondaryCta}
        </a>
      </div>
    </div>
    <div class="md:col-span-5 relative order-1 md:order-2 mb-lg md:mb-0">
      <div class="relative w-full aspect-[3/4] rounded-2xl overflow-hidden soot-shadow border-8 border-surface transform md:rotate-3 hover:rotate-0 transition-transform duration-500">
        <img
          alt={heroProduct.name}
          class="w-full h-full object-cover aspect-[3/4]"
          src={heroProduct.heroImage}
          loading="eager"
        />
      </div>
      <!-- Floating Badge -->
      <div class="absolute -bottom-6 bg-secondary text-on-secondary p-6 rounded-xl soot-shadow transform md:-rotate-6 left-0">
        <p class="font-headline-sm text-headline-sm">{heroProduct.price}</p>
        <p class="text-label-sm font-label-sm opacity-80 uppercase">{heroProduct.priceNote}</p>
      </div>
    </div>
  </div>
</section>
