---
import { Image } from 'astro:assets';
import { menuItems } from '../../data/copy';
import { buildWALink } from '../../utils/wa';

import nasiDusImg from '../../assets/Nasi-ayam-bakar-besar-per-dus-22000.jpeg';
import nasiBesarImg from '../../assets/Nasi-ayam-bakar-besar-styrofoam-20000.jpeg';
import nasiKecilImg from '../../assets/Nasi-ayam-bakar-kecil-styrofoam-12000.jpeg';

const images: Record<string, ImageMetadata> = {
  'nasi-ayam-bakar-besar-dus': nasiDusImg,
  'nasi-ayam-bakar-besar-styrofoam': nasiBesarImg,
  'nasi-ayam-bakar-kecil-styrofoam': nasiKecilImg,
};
---

<section class="py-xl bg-surface px-gutter" id="menu">
  <div class="max-w-[1200px] mx-auto">
    <div class="mb-lg text-center md:text-left">
      <h2 class="text-headline-md font-headline-md text-primary mb-xs">Menu Unggulan</h2>
      <div class="h-1 w-20 bg-secondary rounded-full md:mx-0 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-base md:gap-lg">
      <!-- Main Item (Per Dus) -->
      <div class="md:col-span-8 group relative rounded-2xl overflow-hidden soot-shadow bg-surface-container-high border border-outline-variant/30 flex flex-col md:flex-row">
        <div class="md:w-1/2 overflow-hidden">
          <Image
            src={images[menuItems[0].id]}
            alt={menuItems[0].name}
            class="w-full h-64 md:h-full object-cover group-hover:scale-105 transition-transform duration-700"
            width={600}
            height={400}
            quality={80}
          />
        </div>
        <div class="p-lg md:w-1/2 flex flex-col justify-center">
          <span class="text-secondary font-label-md mb-xs uppercase tracking-widest">{menuItems[0].label}</span>
          <h3 class="text-headline-sm font-headline-sm mb-base text-on-surface">{menuItems[0].name}</h3>
          <p class="text-body-md font-body-md text-on-surface-variant mb-lg">{menuItems[0].description}</p>
          <div class="flex items-center justify-between mt-auto">
            <span class="text-headline-sm font-headline-sm text-primary">{menuItems[0].price}</span>
            <a
              class="bg-on-surface text-surface px-4 py-2 rounded-lg font-label-md hover:bg-primary transition-colors md:px-8"
              href={buildWALink(menuItems[0].waMessage)}
              target="_blank"
              rel="noopener noreferrer"
            >
              Pesan
            </a>
          </div>
        </div>
      </div>

      <!-- Side Items -->
      {menuItems.slice(1).map((item) => (
        <div class="md:col-span-4 group rounded-2xl overflow-hidden soot-shadow bg-surface-container-low border border-outline-variant/30">
          <div class="h-48 overflow-hidden">
            <Image
              src={images[item.id]}
              alt={item.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              width={400}
              height={300}
              quality={80}
            />
          </div>
          <div class="p-base">
            <h3 class="text-label-md font-label-md mb-xs">{item.name}</h3>
            <p class="text-primary font-headline-sm text-headline-sm">{item.price}</p>
            <div class="mt-base pt-base border-t border-outline-variant flex justify-between items-center">
              <span class="text-label-sm font-label-sm text-on-surface-variant">{item.priceNote}</span>
              <a
                class="bg-on-surface text-surface px-4 py-2 rounded-lg font-label-md hover:bg-primary transition-colors"
                href={buildWALink(item.waMessage)}
                target="_blank"
                rel="noopener noreferrer"
              >
                Pesan
              </a>
            </div>
          </div>
        </div>
      ))}

      <!-- Brand Value Card -->
      <div class="md:col-span-8 bg-primary-container text-on-primary-container p-lg rounded-2xl flex flex-col md:flex-row items-center gap-lg">
        <div class="text-center md:text-left flex-1">
          <h4 class="text-headline-sm font-headline-sm mb-xs">Bahan Segar Setiap Hari</h4>
          <p class="text-body-md font-body-md opacity-90">Kami hanya menggunakan ayam pilihan yang dipotong setiap subuh dan dibakar dengan arang batok kelapa untuk aroma maksimal.</p>
        </div>
        <div class="flex gap-base">
          <div class="w-12 h-12 rounded-full bg-surface/20 flex items-center justify-center">
            <span class="material-symbols-outlined">restaurant</span>
          </div>
          <div class="w-12 h-12 rounded-full bg-surface/20 flex items-center justify-center">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">eco</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
